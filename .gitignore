# AgentCommander runtime data — never commit any of these.
# Endpoints + API keys live in the SQLite DB inside the user-data dir
# (XDG_DATA_HOME / %APPDATA% / Application Support); these patterns are
# defence-in-depth for the case where someone points the DB at the repo.
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db
*.db-journal
*.db-wal
*.db-shm
agentcommander_data/
typecast_cache/
typecast/models-catalog.json
.env
.env.local
.env.*.local
secrets.json
credentials.json

.DS_Store
.idea/
.vscode/
*.log

# Local sandbox the user runs the agent against — never commit anything
# the program wrote into its working directory.
AgentTesting/

# Project-local AgentCommander state (DB, fs permissions, etc).
# Each working directory has its own .agentcommander/db.sqlite — keeps
# providers, role assignments, and conversation history isolated per
# project. The DB carries endpoints + api_keys; never commit it.
.agentcommander/

# Chat transcripts written by the chat-log feature
# (<working_dir>/logs/<conversation-start-time>.log). User-facing, can
# contain quoted file content / outputs / arbitrary user messages.
logs/
